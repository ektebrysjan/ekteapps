<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="steps.db" />
        <include domain="sharedpref" path="steps_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="steps.db" />
        <include domain="sharedpref" path="steps_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
