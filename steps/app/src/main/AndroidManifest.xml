<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Reading step data. On API 29+ this is a runtime permission requested at launch. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- No FOREGROUND_SERVICE / POST_NOTIFICATIONS / RECEIVE_BOOT_COMPLETED: counting runs via
         WorkManager with no persistent notification, and WorkManager reschedules across reboots. -->

    <!-- This device must have a step-counter sensor to be useful (not required, so the app
         still installs; we handle absence gracefully in code). -->
    <uses-feature
        android:name="android.hardware.sensor.stepcounter"
        android:required="false" />

    <!-- NOTE: no INTERNET permission — the app never sends data off the device. -->

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Steps"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Steps">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
